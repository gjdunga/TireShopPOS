# Tire Shop POS Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# DunganSoft Technologies, March 2026

# ---- Application ----
APP_NAME="Tire Shop POS"
APP_DEBUG=false
APP_TIMEZONE=America/Denver
APP_URL=http://localhost
APP_LOG_LEVEL=error

# ---- Database ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tire_shop
DB_USERNAME=root
DB_PASSWORD=
DB_PERSISTENT=true

# ---- PlateToVIN API (Vehicle Lookup) ----
# Register at platetovin.com. $0.05 per lookup, cached 90 days.
PLATETOVIN_API_KEY=

# ---- Session ----
# Session lifetime in seconds (default: 3600 = 1 hour)
SESSION_LIFETIME=3600

# ---- Backup ----
# Path for daily MySQL dumps (absolute path)
BACKUP_PATH=/var/backups/tire_shop
# Path to photo storage (for rsync backup)
PHOTO_PATH=/var/www/tire_shop/storage/photos
