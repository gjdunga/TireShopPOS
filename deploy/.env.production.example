# ============================================================================
# TireShopPOS: Production Environment Template
#
# Copy to .env and fill in your credentials before running the installer.
# See docs/TireShopPOS_Installation_Guide.docx for step-by-step setup.
#
# DunganSoft Technologies, March 2026
# ============================================================================

# ---- Application ----
APP_NAME="Tire Shop POS"
APP_DEBUG=false
APP_TIMEZONE=America/Denver
APP_URL=https://pos.example.com
APP_LOG_LEVEL=error

# ---- Database ----
# Get these from Virtualmin: Edit Virtual Server > database section.
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_PERSISTENT=true

# ---- Vehicle Lookup (optional) ----
# The plate-to-VIN provider and API key are now configured in the UI
# (Settings > Vehicle Lookup). This env var is a fallback only.
# If you set a provider in the UI, this value is ignored.
PLATETOVIN_API_KEY=

# ---- Session ----
SESSION_LIFETIME=3600

# ---- CORS ----
# Set to your exact domain. Use * only for development.
CORS_ORIGIN=https://pos.example.com

# ---- Email (SMTP) ----
# Leave SMTP_HOST blank to use server MTA (Postfix).
# Set for external SMTP (Gmail, SendGrid, etc.).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_ENCRYPTION=tls

# ---- SMS (Flowroute) ----
# Configure in Settings > Notifications or set here as fallback.
# SMS_FROM_NUMBER is your Flowroute DID (e.g., 17195550100).

# ---- Notification Cron ----
# API key for scripts/deliver-notifications.sh cron job.
# Create one in Settings > API Keys, paste the raw key here.
NOTIFICATION_API_KEY=

# ---- Backup ----
BACKUP_PATH=/home/user/backups/db
PHOTO_PATH=/home/user/domains/pos.example.com/public_html/uploads/photos
