# ============================================================================
# Tire Shop POS: Production Environment Template
# pos.BearlyUsed.net
#
# Copy to .env.production and fill in credentials before deploying.
# deploy.sh will copy this to the app's .env on first run.
#
# DunganSoft Technologies, March 2026
# ============================================================================

# ---- Application ----
APP_NAME="Bearly Used Tire Shop POS"
APP_DEBUG=false
APP_TIMEZONE=America/Denver
APP_URL=https://pos.bearlyused.net
APP_LOG_LEVEL=error

# ---- Database ----
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=bearlyused_tirepos
DB_USERNAME=
DB_PASSWORD=
DB_PERSISTENT=true

# ---- PlateToVIN API (Vehicle Lookup) ----
PLATETOVIN_API_KEY=

# ---- Session ----
SESSION_LIFETIME=3600

# ---- CORS ----
CORS_ORIGIN=https://pos.bearlyused.net

# ---- Backup ----
BACKUP_PATH=/home/bearlyused/backups/db
PHOTO_PATH=/home/bearlyused/domains/pos.bearlyused.net/public_html/uploads/photos
